@page "/register"
@layout Layout.EmptyLayout

<div class="page-container">
    
    <div class="white-header-section">
        <img src="images/Arvia.png" alt="Arvia Logo" style="width: 380px; height: auto; object-fit: contain;" />
    </div>

    <div class="content-section">
        <h1 class="arvia-title">Create Account</h1>
        <p class="arvia-subtitle">Join the Arvia community</p>

        <input type="text" class="arvia-input" placeholder="Choose Name" />
        <input type="password" class="arvia-input" placeholder="Password" />
        <input type="password" class="arvia-input" placeholder="Confirm Password" />

        <button class="arvia-btn-primary">Register</button>

        <div class="arvia-link">
            Already have an account? <a href="/">Log In</a>
        </div>
        </div>
</div>